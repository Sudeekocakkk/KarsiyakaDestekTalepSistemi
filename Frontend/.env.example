# Backend API adresi. Backend varsayılan olarak 5000 portunda çalışır (bkz. Backend/.env PORT).
VITE_API_BASE_URL=http://localhost:5000/api

# Backend statik dosya (yüklenen fotoğraflar) kök adresi — /uploads altındaki dosyalar için.
# Genellikle VITE_API_BASE_URL ile aynı origin, sadece /api olmadan.
VITE_FILE_BASE_URL=http://localhost:5000
