DATABASE_URL="postgresql://postgres:postgres@localhost:5432/karsiyaka_destek?schema=public"

PORT=5000
JWT_SECRET="degistirin-bu-cok-gizli-bir-anahtar-olmali"
JWT_EXPIRES_IN=1d

# =========================
# SMTP / E-posta Ayarları
# =========================
# Belediye SMTP sunucusu üzerinden e-posta gönderimi için kullanılır
# (Backend/src/utils/mailer.js). Gerçek şifreyi bu dosyaya değil, yalnızca
# Backend/.env dosyasına yazın — .env.example yalnızca örnek/şablondur.

SMTP_HOST=mail.karsiyaka.bel.tr
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=bimdestek@karsiyaka.bel.tr
SMTP_PASS=[BURAYA_SMTP_SIFRESI]
SMTP_FROM_EMAIL=bimdestek@karsiyaka.bel.tr
SMTP_FROM_NAME=Karşıyaka Destek

# false yapılırsa mail kuyruğuna yeni iş eklenmez (bildirimler kapanır).
# Tanımsızsa güvenli varsayılan olarak "açık" kabul edilir.
EMAIL_NOTIFICATIONS_ENABLED=true

# SMTP bağlantı testi (npm run test:smtp) için test mailinin gönderileceği adres.
# Boş bırakılırsa yalnızca bağlantı/kimlik doğrulama testi yapılır, mail gönderilmez.
SMTP_TEST_TO=[BURAYA_TEST_MAIL_ADRESI]

# --- Eski Mailtrap test ayarları (artık kullanılmıyor) ---
# Kod artık yukarıdaki SMTP_* değişkenlerini okuyor; bu satırlar yalnızca
# referans amaçlı bırakıldı, aktif değil.
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_FROM="Karşıyaka Destek <bildirim@karsiyakadestek.local>"

FRONTEND_URL=http://localhost:5173

REDIS_URL=redis://localhost:6379
